{
  "name": "@sulthonzh/mcp-audit",
  "version": "1.2.0",
  "description": "Security scanner for MCP (Model Context Protocol) servers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-audit": "dist/cli.js"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "test": "node --import tsx --test test/*.test.ts",
    "test:coverage": "c8 node --import tsx --test test/*.test.ts",
    "test:watch": "node --import tsx --test --watch test/*.test.ts",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm test",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "security",
    "audit",
    "ai",
    "agent",
    "scanner",
    "vulnerability",
    "cli"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "fs-extra": "^11.1.0",
    "js-yaml": "^4.1.0",
    "simple-git": "^3.20.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.6",
    "@types/node": "^20.0.0",
    "c8": "^11.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.22.4",
    "typescript": "^5.2.0",
    "typescript-eslint": "^8.62.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sulthonzh/mcp-audit.git"
  },
  "bugs": {
    "url": "https://github.com/sulthonzh/mcp-audit/issues"
  },
  "homepage": "https://github.com/sulthonzh/mcp-audit#readme",
  "publishConfig": {
    "access": "public"
  }
}
